#!/bin/bash
# Source: http://unix.stackexchange.com/a/24636/18876
# See also: dateutils.ddiff
set -o pipefail
shopt -qs extglob

: ${DATE:=date}

hasCustomWhat=; [ -n "$DATEDIFF_WHAT" ] && hasCustomWhat=t
: ${DATEDIFF_COMMAND:=$(basename "$0")}
: ${DATEDIFF_WHAT:='the difference between two DATEs or TIMEs / the passed DATE or TIME and now'}
: ${DATEDIFF_INPUT_ARGS:='-f|--file FILE [-f ...]|DATE|TIME [DATE|TIME]'}
: ${DATEDIFF_ADDITIONAL_EXIT_STATUS:='    4	Invalid DATE(s) / TIME(s) passed.
    5	A FILE could not be read.
    99	Empty input; no DATE / TIME could be read.'}
readonly generalArgs='[-u|--utc|--universal]'
readonly availableOutputFormats='s[econd[s]]|m[inute[s]]|h[our[s]]|d[ay[s]]|w[eek[s]]|mo[nth[s]]|y[ear[s]]|g[eneration[s]]|whole-units|smallest-unit|best-unit|largest-unit|all|textform'
readonly prefixSuffixArgs='[--prefix PREFIX [--prefix ...]] [--suffix SUFFIX [--suffix ...]]'
readonly newerOlderArgs='--newer|--older [-]AGE[SUFFIX]'
readonly comparisonArgs='-lt|-le|-eq|-ne|-ge|-gt [-]AGE[SUFFIX] [-a|--absolute]'
readonly timeslotArgs='-w|--within|-W|--outside s[econd]|m[inute]|h[our]|d[ay]|w[eek]|mo[nth]|y[ear]'
getShortUsage()
{
    printf %s "$generalArgs [-o|--output ${availableOutputFormats}] $prefixSuffixArgs [--no-direction] [${newerOlderArgs}|${comparisonArgs}|${timeslotArgs}]"
}
printShortUsage()
{
    printf 'Usage: [DATEDIFF_OUTPUT_FORMAT=%s] %q %s\n' "$availableOutputFormats" "$DATEDIFF_COMMAND" "$generalArgs [-?|-h|--help] ..."
    echo
    cat <<HELPDESCRIPTION
Calculate ${DATEDIFF_WHAT}, and print it in flexible units depending on the magnitude of the difference.
HELPDESCRIPTION
    echo
    printf 'Usage: %q %s\n' "$DATEDIFF_COMMAND" "... [-o|--output ${availableOutputFormats}] $prefixSuffixArgs [-a|--absolute] [--no-direction] $DATEDIFF_INPUT_ARGS"
    echo
    if [ ! "$hasCustomWhat" ]; then
	cat <<HELPDESCRIPTION
Print the passed difference in seconds or days in flexible units depending on
the magnitude of the difference.
HELPDESCRIPTION
	echo
	printf 'Usage: %q %s\n' "$DATEDIFF_COMMAND" "... [-o|--output ${availableOutputFormats}] $prefixSuffixArgs -s|--seconds|-d|--days NUM [-a|--absolute|--no-direction]"
	echo
    fi
    cat <<HELPDESCRIPTION
Test whether ${DATEDIFF_WHAT} is greater / smaller than AGE.
Can be combined with -o|--output to print the actual difference if the test
fails.
Note: -lt|-le|-eq|-ne|-ge|-gt are purely mathematical comparisons with the
difference of DATE|TIME to now / the second passed DATE|TIME to the first.
--newer|--older instead are (signed) age comparisons; future dates / dates where
the second passed DATE|TIME is greater than the first are always newer (unless
-AGE, which asserts that it must be at least AGE in the future) and never older.
This is different from a comparison with --absolute, which would treat
(greater / smaller) differences the same regardless of being in the past or
future.
SUFFIX may be 's' for seconds (the default), 'm' for minutes, 'h' for hours, 'd'
for days, 'w' for weeks, 'mo' for months, 'y' for years, 'g' for generations.
HELPDESCRIPTION
    echo
    printf 'Usage: %q %s\n' "$DATEDIFF_COMMAND" "... $newerOlderArgs $DATEDIFF_INPUT_ARGS"
    printf 'Usage: %q %s\n' "$DATEDIFF_COMMAND" "... $comparisonArgs $DATEDIFF_INPUT_ARGS"
    echo
    cat <<HELPDESCRIPTION
Test whether ${DATEDIFF_WHAT} falls inside / outside TIMESLOT.
TIMESLOT can be one of second|minute|hour|day|week|month|year.
HELPDESCRIPTION
    echo
    printf 'Usage: %q %s\n' "$DATEDIFF_COMMAND" "... $timeslotArgs $DATEDIFF_INPUT_ARGS"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$DATEDIFF_COMMAND"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
For example, --within day would yield false despite an actual age difference of
only seconds if one is before midnight and the other shortly after midnight,
whereas "-le 1d" would yield true as long as the actual difference is within
86400 seconds.
    --utc|--universal|-u
			Use Coordinated Universal Time (UTC) instead of local
			time for all dates.
    --absolute|-a	Print the absolute (positive) difference, i.e. ignore
			which of the two dates is earlier / the sign of the
			passed difference.
    --no-direction	No "in / ago" when comparing to now / passed
			differences.
    --prefix PREFIX	Put PREFIX before the output.
    --suffix SUFFIX	Append SUFFIX at the end.
    --file|-f FILE	Read DATE(s) / TIME(s) (one per line, possibly followed
			by tab-separated other content, which is taken over to
			the output; empty DATE / TIME is tolerated) from FILE.
			These are then each compared to now / (as the second
			date to) the passed DATE / TIME (being the first).
$DATEDIFF_ADDITIONAL_OPTIONS
EXIT STATUS:
    0	Complete success.
    1	The comparison failed; at least one DATE / TIME did not pass it.
    2	Bad invocation, wrong or missing command-line arguments.
$DATEDIFF_ADDITIONAL_EXIT_STATUS
HELPTEXT
}

ensureSingleDifference()
{
    [ "$hasDifference" ] || return 0
    echo >&2 'ERROR: Cannot combine -s|--seconds with -d|--days.'
    echo >&2
    printUsage "$0" >&2
    exit 2
}

isNegated=
parseAge()
{
    local isNegate="${1?}"; shift
    case "${1?}" in
	?(-)+([0-9])?(s))		    age="${1%s}";;
	?(-)+([0-9])m)			    age=$((${1%m} * 60));;
	?(-)+([0-9])h)			    age=$((${1%h} * 3600));;
	?(-)+([0-9])d)			    age=$((${1%d} * 86400));;
	?(-)+([0-9])w)			    age=$((${1%w} * 86400 * 7));;
	?(-)+([0-9])mo)			    age=$((${1%mo} * 86400 * 30));;
	?(-)+([0-9])y)			    age=$((${1%y} * 86400 * 365));;
	?(-)+([0-9])g)			    age=$((${1%g} * 86400 * 9131));;
	*)				    printf >&2 'ERROR: Invalid AGE: "%s".\n\n' "$1"; printUsage "$0" >&2; exit 2;;
    esac
    if [ "$isNegate" ]; then
	let age=-age
	isNegated=t
    fi
}
timeformat='%s'
parseTimeslot()
{
    case "$1" in
	s?(econd))			    timeformat='%s';;
	m?(inute))			    timeformat='%F_%H:%M';;
	h?(our))			    timeformat='%F_%H';;
	d?(ay))				    timeformat='%F';;
	w?(eek))			    timeformat='%G_%V';;
	mo?(nth))			    timeformat='%Y_%m';;
	y?(ear))			    timeformat='%Y';;
	*)				    printf >&2 'ERROR: Invalid TIMESLOT: "%s".\n\n' "$1"; printUsage "$0" >&2; exit 2;;
    esac
}

typeset -a dateArgs=()
isAbsolute=
isDirection=t
hasDifference=
secondsDiff=
daysDiff=
outputFormat="$DATEDIFF_OUTPUT_FORMAT"
prefix=
suffix=
spanCompareOp=
formatCompareOp=
typeset -a filespecs=()
dateArgOffset=1
option() { :; }
parameter() { :; }
endOfOptionsAndParameters() { :; }
noUnderstand() { :; }
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--get-short-usage)
			shift; getShortUsage; exit 0;;
	--print-usage)	shift; printUsage "$0"; exit 2;;
	--understands)	shift
			option() { printf 1; exit 0; }
			parameter() { printf 2; exit 0; }
			endOfOptionsAndParameters() { exit 99; }
			noUnderstand() { exit 1; }
			;;

	--universal|--utc|-u)
			dateArgs+=("$1"); shift; option;;
	--absolute|-a)	isAbsolute=t; shift; option;;
	--no-direction)	isDirection=; shift; option;;
	--output|-o)	shift; outputFormat="${1:?}"; shift; parameter;;
	--prefix)	shift; prefix+="${1?}"; shift; parameter;;
	--suffix)	shift; suffix+="${1?}"; shift; parameter;;

	--seconds|-s)	shift; ensureSingleDifference; secondsDiff="${1:?}"; shift; hasDifference=t; parameter;;
	--days|-d)	shift; ensureSingleDifference; daysDiff="${1:?}"; shift; hasDifference=t; parameter;;

	--newer)	shift; parseAge t "${1:?}"; shift; spanCompareOp=-gt; parameter;;
	--older)	shift; parseAge t "${1:?}"; shift; spanCompareOp=-lt; parameter;;
	-lt|-le|-eq|-ne|-ge|-gt)
			spanCompareOp="$1"; shift; parseAge '' "${1:?}"; shift; parameter;;
	--within|-w)	shift; parseTimeslot "${1:?}"; formatCompareOp='='; shift; parameter;;
	--outside|-W)	shift; parseTimeslot "${1:?}"; formatCompareOp='!='; shift; parameter;;

	--file|-f)	shift; filespecs+=("${1:?}"); shift; dateArgOffset=0; parameter;;
	--file=*)	filespecs+=("${1#--file=}"); shift; dateArgOffset=0; option;;

	--)		endOfOptionsAndParameters; [ "$hasDifference" ] || shift; break;;
	-*)		noUnderstand; { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		endOfOptionsAndParameters; break;;
    esac
done
if [ "$hasDifference" ] && [ ${#filespecs[@]} -gt 0 ]; then
    echo 'ERROR: Cannot combine -s|--seconds|-d|--days with -f|--file.'
    echo
    printUsage "$0"
    exit 2
elif [ "$isNegated" ] && [ "$isAbsolute" ]; then
    echo 'ERROR: Cannot combine -a|--absolute with --newer|--older; use -lt|-le|-eq|-ne|-ge|-gt instead.'
    echo
    printUsage "$0"
    exit 2
fi >&2
if [ -n "$spanCompareOp" ] || [ -n "$formatCompareOp" ]; then
    if [ "$hasDifference" ]; then
	echo 'ERROR: Cannot combine -s|--seconds|-d|--days with --newer|--older|-lt|-le|-eq|-ne|-ge|-gt|--within|-w|--outside|-W.'
	echo
	printUsage "$0"
	exit 2
    elif (($# < dateArgOffset || $# > dateArgOffset + 1)); then
	printUsage "$0"
	exit 2
    fi
elif [ -n "$secondsDiff" ]; then
    if [ $# -gt 0 ]; then
	printUsage "$0"
	exit 2
    fi
elif [ -n "$daysDiff" ]; then
    if [ $# -gt 0 ]; then
	printUsage "$0"
	exit 2
    fi
elif (($# < dateArgOffset || $# > dateArgOffset + 1)); then
    printUsage "$0"
    exit 2
fi >&2

[ -n "$NOW" ] \
    && getNow() { printf %s "$NOW"; } \
    || getNow() { printf '%(%s)T' -1; }

getDate()
{
    if [ "$timeformat" = '%s' ] && [[ "${1:?}" =~ ^@[0-9]+$ ]]; then
	printf %d "${1#@}"  # Optimization if the passed date is already in seconds since the epoch.
    else
	"$DATE" "${dateArgs[@]}" --date="${1:?}" "+${timeformat:?}"
    fi
}

parseDates()
{
    if [ $# -eq 1 ]; then
	d1=$(getDate "@$(getNow)") \
	    && d2=$(getDate "$1")
    else
	d1=$(getDate "$1") \
	    && d2=$(getDate "$2")
    fi || return 4
}

isOutput()
{
    { [ -z "$spanCompareOp" ] && [ -z "$formatCompareOp" ]; } || [ -n "$outputFormat" ]
}

addDiffUnit()
{
    local diff="$1"; shift
    local unit="$1"; shift

    [ -n "$diff" ] || return
    [ "$diff" = 0 -a "$unit" != second ] && return	# Skip values that are zero, but keep at least "0 seconds" as the pathological corner case.
    local flooredDiff="${diff%.*}"; flooredDiff=${flooredDiff#-}
    [ ${#flooredDiff} -gt 4 ] && return	# Skip values that are too large (>9999).

    local unitPlural='s'
    [ "${diff#-}" = '1' ] && unitPlural=

    diffInUnits+=("$diff ${unit}${unitPlural}")
}
calculateUnit()
{
    local diff=$1; shift
    local unit=$1; shift
    local divisor=$1; shift
    local unitDiff=$(divround $((100 * diff / divisor)))
    [ -n "$diff" ] || return
    addDiffUnit "$unitDiff" "$unit"
}
printCalculated()
{
    local diff=$1; shift
    local divisor=$1; shift
    local unitDiff=$(divround $((100 * diff / divisor)))
    local flooredDiff="${unitDiff%.*}"
    printf '%s%d%s%s\n' "$prefix" $flooredDiff "$suffix" "$addendum"
}
printSingleUnit()
{
    printf '%s%d%s%s\n' "$prefix" "${1:?}" "$suffix" "$addendum"
}
printOne()
{
    printf '%s%s%s\n' "$prefixAndDirectionPrefix" "${1:?}" "$suffixAndDirectionSuffix"
}

diffOneDate()
{
    local directionPrefix=
    local directionSuffix=
    local sigil=
    typeset -a diffInUnits=()
    local status=0
    if [ -n "$spanCompareOp" ] || [ -n "$formatCompareOp" ]; then
	parseDates "$@" || return $?
	if \
	    if [ -n "$formatCompareOp" ]; then
		[ "$d1" $formatCompareOp "$d2" ]
	    else
		local secondsDiff=$((d2 - d1))
		[ "$isAbsolute" ] \
		    && secondsDiff=$((secondsDiff < 0 ? -secondsDiff : secondsDiff))
		[ $secondsDiff ${spanCompareOp:?} $age ]
	    fi
	then
	    return 0
	else
	    isOutput || return 1
	    if [ -n "$formatCompareOp" ]; then
		timeformat='%s' parseDates "$@"
		local secondsDiff=$((d2 - d1))
	    fi
	    status=1
	fi
    elif [ -n "$secondsDiff" ]; then
	:
    elif [ -n "$daysDiff" ]; then
	if [ "$isAbsolute" ]; then
	    daysDiff=$((daysDiff < 0 ? -daysDiff : daysDiff))
	elif [ "$isDirection" ]; then
	    if [ $daysDiff -eq 0 ]; then
		diffInUnits+=('today')
	    elif [ $daysDiff -gt 0 ]; then
		directionPrefix='in '
	    else
		daysDiff=$((-daysDiff))
		sigil='-'
		directionSuffix=' ago'
	    fi
	fi
	if [ $daysDiff -eq 0 ]; then
	    diffInUnits+=('0 days')
	fi
    else
	parseDates "$@" || return $?
	local secondsDiff=$((d2 - d1))
	[ $# -eq 1 ] || isDirection=    # Disable direction if two dates are given.
    fi
    if [ -n "$secondsDiff" ]; then
	if [ "$isAbsolute" ]; then
	    secondsDiff=$((secondsDiff < 0 ? -secondsDiff : secondsDiff))
	elif [ "$isDirection" ]; then
	    if [ $secondsDiff -eq 0 ]; then
		diffInUnits+=('just now')
	    elif [ $secondsDiff -gt 0 ]; then
		directionPrefix='in '
	    else
		secondsDiff=$((-secondsDiff))
		sigil='-'
		directionSuffix=' ago'
	    fi
	elif [ $secondsDiff -eq 0 ]; then
	    diffInUnits+=('at a single point in time')
	fi
    fi
    if [ -z "$daysDiff" ]; then
	[ "${secondsDiff:0:1}" = '-' ] \
	    && local daysDiff=-$(( (${secondsDiff#-} + 43200) / 86400 )) \
	    || local daysDiff=$(( (secondsDiff + 43200) / 86400 ))
    fi
    if [ -z "$secondsDiff" ] && [ "$isDirection" ] && [ ! "$isAbsolute" ] && [ $daysDiff -eq 1 ]; then
	if [ "$sigil" = - ]; then
	    diffInUnits+=('yesterday' '1 day ago')
	    directionSuffix=''
	    local daysDiff=
	else
	    diffInUnits+=('tomorrow' 'in 1 day')
	    directionPrefix=''
	    local daysDiff=
	fi
    fi
    local prefixAndDirectionPrefix="${prefix}${directionPrefix}"
    local suffixAndDirectionSuffix="${directionSuffix}${suffix}${addendum}"

    addDiffUnit   "$secondsDiff" second
    calculateUnit "$secondsDiff" minute 60
    calculateUnit "$secondsDiff" hour 3600
    calculateUnit "$secondsDiff" day 86400
    [ -z "$secondsDiff" ] && calculateUnit "$daysDiff"    day 1
    calculateUnit "$daysDiff"    week 7
    calculateUnit "$daysDiff"    month 30
    calculateUnit "$daysDiff"    year 365
    calculateUnit "$daysDiff"    generation 9131

    case "${outputFormat:-all}" in
	all)		joinBy ${prefixAndDirectionPrefix:+--prefix "$prefixAndDirectionPrefix"} ${suffixAndDirectionSuffix:+--suffix "$suffixAndDirectionSuffix"} ' = ' "${diffInUnits[@]}";;

	s?(econd?(s)))  printSingleUnit ${sigil}${secondsDiff};;
	m?(inute?(s)))  printCalculated ${sigil}${secondsDiff} 60;;
	h?(our?(s)))    printCalculated ${sigil}${secondsDiff} 3600;;
	d?(ay?(s)))	printSingleUnit ${sigil}${daysDiff};;
	w?(eek?(s)))    printCalculated ${sigil}${daysDiff} 7;;
	mo?(nth?(s)))   printCalculated ${sigil}${daysDiff} 30;;
	y?(ear?(s)))    printCalculated ${sigil}${daysDiff} 365;;
	g?(eneration?(s)))
			printCalculated ${sigil}${daysDiff} 9131;;

	whole-units)    # Choose all units that are not just a fraction; i.e. do not start with 0.
			typeset -a wholeUnits=()
			for unit in "${diffInUnits[@]}"
			do
			    [ "${unit:0:1}" = 0 -o "${unit:0:2}" = -0 ] || wholeUnits+=("$unit")
			done
			if [ ${#wholeUnits[@]} -eq 0 ]; then
			    printOne "${diffInUnits[-1]}"
			else
			    joinBy ${prefixAndDirectionPrefix:+--prefix "$prefixAndDirectionPrefix"} ${suffixAndDirectionSuffix:+--suffix "$suffixAndDirectionSuffix"} ' = ' "${wholeUnits[@]}"
			fi
			;;
	smallest-unit)  printOne "${diffInUnits[0]}";;
	largest-unit)   printOne "${diffInUnits[-1]}";;
	best-unit)	# Choose the largest one that is not just a fraction; i.e. does not start with 0.
			for ((i = $((${#diffInUnits[@]} - 1)); i >= 0; i--))
			do
			    best="${diffInUnits[i]}"
			    [ "${best:0:1}" = 0 -o "${best:0:2}" = -0 ] || break
			done
			printOne "$best"
			;;
	textform)	alternatives=()
			for d in "${diffInUnits[@]}"
			do
			    alternatives+=("${directionPrefix}${d}${directionSuffix}")
			done
			[ ${#diffInUnits[@]} -gt 1 ] && alternatives+=("$(joinBy ${directionPrefix:+--prefix "$directionPrefix"} ${directionSuffix:+--suffix "$directionSuffix"} ' = ' "${diffInUnits[@]}")")
			joinBy --prefix "${prefix}[" --suffix "]${suffix}${addendum}" '|' "${alternatives[@]}"
			;;
	*)		printf >&2 'ERROR: Invalid output format: %s\n' "$outputFormat"; exit 2;;
    esac
    return $status
}

diffInput()
{
    local line dateOrTime addendum status
    while IFS=$'\n' read -r line || [ -n "$line" ]
    do
	dateOrTime="${line%%$'\t'*}"
	addendum="${line#"$dateOrTime"}"
	if [ -z "$dateOrTime" ]; then
	    isOutput && printf '%s\n' "$addendum"
	    continue
	fi

	diffOneDate "$@" "$dateOrTime" && : ${status:=0} || { exitStatus=$?; if [ $exitStatus -gt ${status:-0} ]; then status=$exitStatus; fi; }
    done
    return ${status:-99}
}

if [ ${#filespecs[@]} -gt 0 ]; then
    if [ "${filespecs[*]}" = '-' ]; then
	diffInput "$@"
    else
	cat -- "${filespecs[@]}" \
	    | diffInput "$@"
	typeset -a states=("${PIPESTATUS[@]}")
	[ ${states[0]} -ne 0 ] && exit 5 || exit ${states[1]}
    fi
else
    diffOneDate "$@"
fi
